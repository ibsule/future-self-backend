<html>
  <head>
    <meta charset='utf-8' />
    <title>Reset password | Futureself</title>
  </head>

  <body style='margin:0; padding:24px; font-family: Georgia, serif; color:#1a1a1a;'>
    <p>Hello {{name}},</p>
    <p>We received a request to reset your Futureself password.</p>
    <p>
      <a href='{{resetUrl}}' style='color:#1a1a1a;'>Reset your password</a>
